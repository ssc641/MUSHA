rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================
    // VENDOR INVENTORY (Mall + Auto Lot items)
    // =========================================
    match /vendor_inventory/{item} {
      // Anyone can read active listings (public marketplace)
      allow read: if resource.data.status == 'active'
                    || resource.data.status == 'pending';

      // Vendors can submit new items (goes to pending)
      allow create: if request.resource.data.keys().hasAll([
        'name', 'price', 'vendorId', 'status', 'placementTag'
      ]);

      // Allow updates for: approval, sold status, promotions
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'status', 'approvedAt',
          'isSold', 'soldAt',
          'onPromotion', 'priorityScore',
          'image', 'description', 'whatsapp', 'facebook', 'email'
        ]);

      // Vendors can delete their own; admin can delete any
      allow delete: if true;
    }

    // =========================================
    // VENDORS (Shop accounts)
    // =========================================
    match /vendors/{vendor} {
      // Needed for login/registration lookups
      allow read: if true;

      // Registration
      allow create: if request.resource.data.keys().hasAll([
        'shopName', 'email', 'password'
      ]);

      // Allow password resets and lastLogin updates only
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'password', 'passwordResetAt', 'lastLogin',
          'whatsapp', 'facebook', 'phone'
        ]);

      // Admin shop deletion
      allow delete: if true;
    }

    // =========================================
    // PASSWORD RESET QUEUE
    // =========================================
    match /password_resets/{reset} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasAll([
        'vendorId', 'vendorEmail', 'status', 'requestedAt'
      ]);

      // Admin approves/rejects
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'completedAt', 'rejectedAt']);

      allow delete: if true;
    }
  }
}