rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /vendor_inventory/{item} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'price', 'category', 'vendorId', 'vendorName', 'status', 'placementTag']) &&
                       request.resource.data.status == "pending" &&
                       request.resource.data.price is number &&
                       request.resource.data.price > 0;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'isSold', 'onPromotion', 'priorityScore', 'soldAt', 'image', 'facebook', 'email', 'whatsapp']);
      allow delete: if true;
    }

    match /vendors/{vendorId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['shopName', 'email', 'phone', 'password']) &&
                       request.resource.data.shopName is string &&
                       request.resource.data.shopName.size() >= 2 &&
                       request.resource.data.email is string &&
                       request.resource.data.email.matches('^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$') &&
                       request.resource.data.phone is string &&
                       request.resource.data.phone.size() >= 8 &&
                       request.resource.data.password is string &&
                       request.resource.data.password.size() >= 6;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['shopName', 'phone', 'whatsapp', 'facebook', 'lastLogin', 'isVerified', 'status', 'passwordResetAt']);
      allow delete: if true;
    }

    match /password_resets/{resetId} {
      allow create: if request.resource.data.keys().hasAll(['vendorId', 'vendorEmail', 'proofPhone', 'vendorShopName', 'status']) &&
                       request.resource.data.status == "pending_admin_review";
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'completedAt', 'rejectedAt']) &&
                       request.resource.data.status in ["completed", "rejected"];
      allow delete: if false;
    }
  }
}
